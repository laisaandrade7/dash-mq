# Credenciais do Onii
ONII_EMAIL=
ONII_PASSWORD=

# Lojas — valor exato do atributo value do <select> no Onii
STORE_ALBATROZ=
STORE_POINT=
STORE_TAGUS=
STORE_CD=

# Caminho de saída dos JSONs (relativo à raiz do projeto)
DATA_OUTPUT_DIR=./data

# Browser: false = abre visível (útil para depurar login)
HEADLESS=false

# ── FTP ──────────────────────────────────────
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_PATH=/public_html/dashboard
FTP_SECURE=false

# true = envia também HTML/CSS/JS (deploy completo)
FTP_FULL_DEPLOY=false
